# Required in production. Used to sign JWT auth tokens.
OPSPILOT_JWT_SECRET=replace-with-a-long-random-secret

# Optional. When unset, OpsPilot uses local JSON persistence.
OPSPILOT_DATA_FILE=.data/workspaces.json

# Optional. Enables Postgres/pgvector infrastructure when used by a DB adapter.
DATABASE_URL=postgres://opspilot:opspilot@127.0.0.1:5432/opspilot

# Embeddings: local is the default and needs no API key.
OPSPILOT_EMBEDDING_PROVIDER=local

# Optional OpenAI embeddings.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic note: native public embeddings are not wired; use local or OpenAI for embeddings.
ANTHROPIC_API_KEY=
